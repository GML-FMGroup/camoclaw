{
  "camoclaw": {
    "date_range": {
      "init_date": "2025-01-20",
      "end_date": "2025-01-23"
    },
    "economic": {
      "initial_balance": 10.0,
      "task_values_path": "./scripts/task_value_estimates/task_values.jsonl",
      "token_pricing": {
        "input_per_1m": 2.5,
        "output_per_1m": 10.0
      }
    },
    "agents": [
      {
        "signature": "kimi-k2.5-agent-10d",
        "basemodel": "moonshotai/kimi-k2.5",
        "enabled": true,
        "tasks_per_day": 1,
        "supports_multimodal": true
      }
    ],
    "agent_params": {
      "max_steps": 25,
      "max_retries": 3,
      "base_delay": 0.5,
      "tasks_per_day": 1,
      "api_timeout": 120
    },
    "evaluation": {
      "use_llm_evaluation": true,
      "meta_prompts_dir": "./eval/meta_prompts"
    },
    "skill": {
      "enabled": true,
      "use_builtin": true
    },
    "evolution": {
      "enabled": true,
      "threshold": 0.6
    },
    "data_path": "./livebench/data/agent_data",
    "gdpval_path": "./gdpval"
  }
}
