# ============================================
# CamoClaw / LiveBench 环境变量示例
# ============================================
# 复制本文件为 .env 并填入你的 API Key（不要提交 .env）
#
# IMPORTANT: Agent 与 Evaluator 可使用不同 API 提供商！
#

# ============================================
# AGENT MODEL API（运行 Agent 时使用）
# ============================================
# 用于 Agent 主模型（如 GLM-4.7、GPT-4、Claude）
# 可使用 OpenAI、SiliconFlow 或其他 OpenAI 兼容 API

# OPENAI_API_KEY=your-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1  # 默认 OpenAI
# OPENAI_API_BASE=https://api.siliconflow.com/v1  # 或 SiliconFlow
# OPENAI_API_BASE=https://openrouter.ai/api/v1   # OpenRouter


# ============================================
# EVALUATION MODEL API（打分用）
# ============================================
# 评估器使用 GPT-4o 对 Agent 提交打分
#
# 推荐：使用真实 OpenAI API 做评估（最稳定）
# - 评估需要 gpt-4o，部分提供商可能不支持
# - OpenAI gpt-4o 质量稳定
# - 评估调用量小于 Agent，成本较低
#
# 未设置时回退到 OPENAI_API_KEY 和 OPENAI_API_BASE

# 方案 1：使用 OpenAI 做评估（推荐）
# EVALUATION_API_KEY=your-openai-api-key-here
# EVALUATION_API_BASE=https://api.openai.com/v1  # 默认，可省略

# 方案 2：与 Agent 使用同一提供商
# （注释掉 EVALUATION_API_KEY 和 EVALUATION_API_BASE 即可）

# 方案 3：使用不同评估模型
# EVALUATION_MODEL=gpt-4o  # 默认，可按需修改


# ============================================
# PRODUCTIVITY TOOLS APIs
# ============================================

# 网页搜索 API（search_web、learn_from_web 等工具必需）
# 可选提供商: "tavily"（默认）、"jina"、"brave"
# WEB_SEARCH_PROVIDER=tavily
# WEB_SEARCH_API_KEY=your-api-key-here

# Brave Search（使用 WEB_SEARCH_PROVIDER=brave）
# 获取 API Key: https://api.search.brave.com/ → Subscription / API Keys
# WEB_SEARCH_PROVIDER=brave
# WEB_SEARCH_API_KEY=your-brave-key
# （或单独设置 BRAVE_API_KEY=...）

# Tavily Search（默认）
# 获取 API Key: https://tavily.com
# TAVILY_API_KEY=your-tavily-key

# Jina AI Search
# 免费 API Key: https://jina.ai
# JINA_API_KEY=your-jina-api-key-here

# Qwen VL OCR API（模型不支持多模态时的 OCR 处理）
# 从阿里云 DashScope 获取: https://dashscope.aliyuncs.com/
# OCR_VLLM_API_KEY=your-dashscope-api-key-here

# E2B API（代码沙箱执行）
# 获取 API Key: https://e2b.dev/
# E2B_API_KEY=your-e2b-key

# Poppler（评估中 PDF 转图；Windows 常需指定）
# 若已安装 poppler 但不在 PATH，设置为其 bin 目录，例如：
# POPPLER_PATH=A:\app\poppler-25.12.0\Library\bin


# ============================================
# SERVICE CONFIGURATION
# ============================================

# MCP 服务端口
# LIVEBENCH_HTTP_PORT=8010


# ============================================
# 配置示例
# ============================================

# 示例 1：全部使用 OpenAI（简单稳定）
# OPENAI_API_KEY=sk-proj-xxxxx
# EVALUATION_API_KEY=sk-proj-xxxxx  # 可与 OPENAI_API_KEY 相同或不同
# WEB_SEARCH_API_KEY=tvly-xxxxx  # Tavily 搜索

# 示例 2：Agent 用 SiliconFlow，评估用 OpenAI（省成本）
# OPENAI_API_KEY=sk-ngksq...  # SiliconFlow key
# OPENAI_API_BASE=https://api.siliconflow.com/v1
# EVALUATION_API_KEY=sk-proj-xxxxx  # 真实 OpenAI key
# EVALUATION_API_BASE=https://api.openai.com/v1
# WEB_SEARCH_API_KEY=tvly-xxxxx

# 示例 3：全部 SiliconFlow（需确认是否支持 gpt-4o）
# OPENAI_API_KEY=sk-ngksq...
# OPENAI_API_BASE=https://api.siliconflow.com/v1
# WEB_SEARCH_API_KEY=tvly-xxxxx
# 若 SiliconFlow 不支持 gpt-4o，可设置 EVALUATION_MODEL 为支持的模型
